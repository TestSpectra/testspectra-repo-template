    "test:api:func": "k6 run k6-scripts/functional_api.ts",
    "test:api:load": "k6 run k6-scripts/load_test.ts",
    "report": "allure generate reports/allure-results --clean -o reports/allure-report && allure open reports/allure-report",
    "report:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:open": "allure open reports/allure-report"
  },
