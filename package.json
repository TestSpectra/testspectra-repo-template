  "main": "index.js",
  "scripts": {
    "setup-env": "bash scripts/setup.sh",
    "setup-env:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "inspector": "ts-node scripts/mobile-inspector.ts",
    "inspector:web": "ts-node scripts/web-inspector.ts",
    "test:web": "wdio run config/wdio.web.conf.ts",
