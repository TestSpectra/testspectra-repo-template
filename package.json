    "@wdio/globals": "^9.17.0",
    "@wdio/local-runner": "^9.20.1",
    "@wdio/mocha-framework": "^9.20.1",
    "@wdio/spec-reporter": "^9.20.0",
    "@wdio/types": "^9.20.0",
    "expect-webdriverio": "^5.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
